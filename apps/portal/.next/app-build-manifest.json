    "/(dashboard)/deploy/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/deploy/page.js"
    ],
    "/(dashboard)/vms/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/vms/page.js"
    ],
    "/(dashboard)/vms/[id]/page": [
      "static/chunks/webpack.js",
